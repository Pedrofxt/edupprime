generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(uuid())
  nome           String
  sobrenome      String
  email          String         @unique
  senha          String
  foto           String?
  telefone       String?
  cpf            String?        @unique
  tipo_usuario   String         @default("ALUNO")
  plano          String         @default("GRATUITO")
  status         String         @default("PENDENTE")
  data_cadastro  DateTime       @default(now())
  ultimo_login   DateTime?
  refreshTokens  RefreshToken[]
  coursesCreated Course[]       @relation("AuthorCourses")
  enrollments    Enrollment[]
  payments       Payment[]
  certificates   Certificate[]
  notifications  Notification[]
  messagesAI     MessageAI[]
  achievements   Achievement[]
  answers        Answer[]
  progresses     Progress[]
  comments       Comment[]
  ratings        Rating[]
  affiliates     Affiliate[]
}

model Course {
  id           String        @id @default(uuid())
  titulo       String
  descricao    String
  categoria    String
  imagem       String?
  banner       String?
  nivel        String
  duracao      Int
  slug         String        @unique
  status       String        @default("PENDENTE")
  author       User          @relation("AuthorCourses", fields: [authorId], references: [id])
  authorId     String
  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]
  quizzes      Quiz[]
  ratings      Rating[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Module {
  id        String   @id @default(uuid())
  titulo    String
  descricao String?
  curso     Course   @relation(fields: [cursoId], references: [id])
  cursoId   String
  lessons   Lesson[]
  order     Int
}

model Lesson {
  id         String     @id @default(uuid())
  titulo     String
  descricao  String?
  video      Video?     @relation(fields: [videoId], references: [id])
  videoId    String?    @unique
  modulo     Module     @relation(fields: [moduleId], references: [id])
  moduleId   String
  order      Int
  duration   Int
  contentUrl String?
  quiz       Quiz?
  progress   Progress[]
  comments   Comment[]
}

model Video {
  id        String  @id @default(uuid())
  titulo    String
  descricao String?
  duracao   Int
  url       String
  thumbnail String?
  provider  String
  lesson    Lesson?
}

model Quiz {
  id        String     @id @default(uuid())
  titulo    String
  descricao String?
  curso     Course     @relation(fields: [courseId], references: [id])
  courseId  String
  lesson    Lesson?    @relation(fields: [lessonId], references: [id])
  lessonId  String?    @unique
  questions Question[]
  score     Float?
}

model Question {
  id        String   @id @default(uuid())
  tipo      String
  enunciado String
  opcoes    String?
  resposta  String?
  ponto     Int      @default(1)
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  quizId    String
  answers   Answer[]
}

model Answer {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
  resposta   String
  correto    Boolean
  tempo      Int
  nota       Float
  createdAt  DateTime @default(now())
}

model Enrollment {
  id             String    @id @default(uuid())
  user           User      @relation(fields: [userId], references: [id])
  userId         String
  course         Course    @relation(fields: [courseId], references: [id])
  courseId       String
  progress       Float     @default(0)
  ultimaAula     String?
  tempoAssistido Int       @default(0)
  status         String    @default("EM_ANDAMENTO")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
}

model Payment {
  id             String   @id @default(uuid())
  usuario        User     @relation(fields: [usuarioId], references: [id])
  usuarioId      String
  valor          Float
  status         String
  metodo         String
  dataPagamento  DateTime @default(now())
  mercadoPagoId  String?
  subscriptionId String?
}

model Certificate {
  id              String   @id @default(uuid())
  nomeAluno       String
  curso           String
  data            DateTime @default(now())
  codigoValidacao String   @unique
  qrCodeUrl       String?
  usuario         User     @relation(fields: [usuarioId], references: [id])
  usuarioId       String
  course          Course   @relation(fields: [courseId], references: [id])
  courseId        String
}

model MessageAI {
  id        String   @id @default(uuid())
  usuario   User     @relation(fields: [usuarioId], references: [id])
  usuarioId String
  pergunta  String
  resposta  String
  tipo      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  usuario   User     @relation(fields: [usuarioId], references: [id])
  usuarioId String
  titulo    String
  corpo     String
  lida      Boolean  @default(false)
  tipo      String
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Progress {
  id         String   @id @default(uuid())
  lesson     Lesson   @relation(fields: [lessonId], references: [id])
  lessonId   String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  percentage Float    @default(0)
  watchedAt  DateTime @default(now())
}

model Comment {
  id        String   @id @default(uuid())
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  lessonId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  content   String
  createdAt DateTime @default(now())
}

model Rating {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  course    Course   @relation(fields: [courseId], references: [id])
  courseId  String
  score     Int
  comment   String?
  createdAt DateTime @default(now())
}

model Coupon {
  id        String   @id @default(uuid())
  codigo    String   @unique
  desconto  Float
  validoAte DateTime
  ativo     Boolean  @default(true)
}

model Affiliate {
  id        String @id @default(uuid())
  usuario   User   @relation(fields: [usuarioId], references: [id])
  usuarioId String
  codigo    String @unique
  comissao  Float
}

model Achievement {
  id        String   @id @default(uuid())
  usuario   User     @relation(fields: [usuarioId], references: [id])
  usuarioId String
  titulo    String
  descricao String?
  nivel     Int      @default(1)
  criadoEm  DateTime @default(now())
}
